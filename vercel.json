{
  "buildCommand": "npx vite build",
  "outputDirectory": "dist",
  "framework": null,
  "routes": [
    { "src": "^/api/(.*)", "dest": "/api/$1" },
    { "src": "^/$", "dest": "/api/landing" },
    { "src": "^/(.*)", "dest": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/remind-classes",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/birthday-wishes",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/demo-reset",
      "schedule": "0 3 * * *"
    }
  ]
}
