{
  "buildCommand": "npx vite build",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    { "source": "/", "destination": "/api/landing" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/remind-classes",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/birthday-wishes",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/demo-reset",
      "schedule": "0 3 * * *"
    }
  ]
}
